{
    // ===== GlassIt Settings =====
    "glassit.alpha": 255,

    // ===== Workbench Settings =====
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.jar": "default"
    },
    "workbench.colorCustomizations": {
        "editorBracketMatch.foreground": "#ff0000",
        "inlineparameters.annotationBackground": "#282a3600",
        "inlineparameters.annotationForeground": "#7b82af",
        "scrollbar.shadow": "#24292e00"
    },
    "workbench.iconTheme": "vscode-icons",
    "workbench.productIconTheme": "fluent-icons",
    "workbench.editorLargeFileConfirmation": 10024,
    "workbench.tree.indent": 16,
    "workbench.startupEditor": "agentSessionsWelcomePage",

    // ===== Window & Explorer =====
    "window.newWindowProfile": "Default",
    "explorer.confirmDelete": false,

    // ===== Breadcrumbs Config =====
    "breadcrumbs.enabled": true,
    "breadcrumbs.symbolPath": "on",
    "breadcrumbs.filePath": "on",

    // ===== Editor Config / Settings =====
    // "editor.fontFamily": "JetBrains Mono, JetBrainsMono Nerd Font, Hack Nerd Font Mono, Monospace",
    "editor.fontFamily": "JetBrains Mono, Monospace",
    "editor.fontSize": 16,
    "editor.fontWeight": 400,
    "editor.lineHeight": 1.2,
    "editor.lineNumbers": "on",
    "editor.folding": true,
    "editor.glyphMargin": true,
    "editor.guides.indentation": true,
    "editor.scrollbar.horizontal": "auto",
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.cursorStyle": "underline",
    "editor.minimap.enabled": true,
    "editor.wordWrap": "on",
    "editor.stickyScroll.enabled": true,
    "editor.cursorBlinking": "expand",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
    "editor.guides.highlightActiveIndentation": true,
    "editor.guides.style": "dotted",
    "editor.guides.bracketPairs": "active",
    "editor.quickSuggestions": {
        "other": "on",
        "comments": "on",
        "strings": "on"
    },
    // "editor.letterSpacing": 1.2

    // ===== Diff Editor =====
    "diffEditor.experimental.showMoves": true,
    "diffEditor.ignoreTrimWhitespace": false,

    // ===== Terminal Config =====
    "terminal.integrated.defaultProfile.windows": "Git Bash",
    "terminal.integrated.defaultProfile.osx": "bash",
    "terminal.integrated.fontFamily": "Firacode Nerd Font, Hack Nerd Font Mono, Hack Nerd Font, Monospace",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.cursorStyle": "underline",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.integrated.stickyScroll.enabled": false,

    // ===== Search =====
    "search.searchView.keywordSuggestions": true,

    // ===== File Associations =====
    "files.associations": {
        "*.css": "tailwindcss",
        "*.scss": "tailwindcss"
    },

    // ===== Settings Sync =====
    "settingsSync.ignoredExtensions": [],

    // ===== Remote Development =====
    "remote.portsAttributes": {
        "3000": {
            "protocol": "https"
        }
    },

    // ===== Git & GitLens =====
    "git.autofetch": true,
    "gitlens.ai.model": "gitkraken",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "gitlens.ai.gitkraken.model": "gemini:gemini-2.5-flash",
    "gitlens.ai.generateCommitMessage.customInstructions": "Generate a conventional commit message. Format: <type>(<scope>): <short_summary>  Then a blank line, then bullet lines like this:  - [+] <Action verb> <feature/change> in `<file_or_module>` <context/details>  Rules: 1) Every change line must start with: \"- [+] \" 2) Use only \"+\" (no *, no -, no mixed types) 3) One line per logical change 4) Include the exact file/module/function in backticks 5) Use professional action verbs (Add, Implement, Improve, Refactor, Update, Fix) 6) No extra text — only the commit message content",

    // ===== GitHub Copilot & Chat =====
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": false
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "github.copilot.nextEditSuggestions.fixes": true,
    "github.copilot.chat.reviewSelection.instructions": [],
    "github.copilot.chat.codesearch.enabled": true,
    "github.copilot.chat.search.keywordSuggestions": true,
    "github.copilot.chat.scopeSelection": true,
    "github.copilot.chat.editor.temporalContext.enabled": true,
    "github.copilot.chat.edits.temporalContext.enabled": true,
    "github.copilot.chat.generateTests.codeLens": true,
    "github.copilot.chat.languageContext.fix.typescript.enabled": true,
    "github.copilot.chat.languageContext.inline.typescript.enabled": true,
    "github.copilot.chat.languageContext.typescript.enabled": true,
    "github.copilot.chat.commitMessageGeneration.instructions": [
        {
            "text": "Give a conventional commit message with a short conventional title and bullet points per file; if a file has multiple changes, list them as indented dashes under the file.\\n Example:\\n feat(auth): add JWT support\\n - auth.js:\\n   - add token generation\\n   - verify middleware ",
        }
    ],

    // ===== GitHub Pull Requests =====
    "githubPullRequests.experimental.chat": true,
    "githubPullRequests.experimental.useQuickChat": true,
    "githubPullRequests.codingAgent.uiIntegration": true,
    "githubPullRequests.fileListLayout": "tree",

    // ===== Chat Agent & MCP =====
    "chat.agent.maxRequests": 200,
    "chat.todoListTool.enabled": true,
    "chat.mcp.autostart": "newAndOutdated",
    "chat.mcp.gallery.enabled": true,
    "chat.mcp.discovery.enabled": {
        "claude-desktop": true,
        "windsurf": true,
        "cursor-global": true,
        "cursor-workspace": true
    },

    // ===== Inline Chat & Parameters =====
    "inlineChat.lineEmptyHint": true,

    // ===== SonarLint =====
    "sonarlint.output.showVerboseLogs": true,
    "sonarlint.automaticAnalysis": false,
    "sonarlint.rules": {
        "css:S4662": {
            "level": "off"
        }
    },

    // ===== Red Hat =====
    "redhat.telemetry.enabled": true,

    // ===== Live Server =====
    "liveServer.settings.donotShowInfoMsg": true,
    "liveServer.settings.donotVerifyTags": true,

    // ===== Language Specific Settings =====
    "[jsonc]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[gradle]": {},
    "[dart]": {
        "editor.formatOnSave": false,
        "editor.formatOnType": true,
        "editor.rulers": [],
        "editor.selectionHighlight": false,
        "editor.tabCompletion": "onlySnippets",
        "editor.wordBasedSuggestions": "off"
    },

    // ===== Dart & Flutter =====
    "dart.previewFlutterUiGuides": true,
    "dart.previewFlutterUiGuidesCustomTracking": true,
    "dart.flutterHotReloadOnSave": "all",
    "dart.hotReloadOnSave": "all",
    "dart.debugExternalPackageLibraries": false,
    "dart.debugSdkLibraries": false,
    "dart.mcpServer": true,
    "chat.agentSessionsViewLocation": "single-view",
    "accessibility.openChatEditedFiles": true,
    "inlineChat.enableV2": true,
    "scm.repositories.explorer": true,
    "gitlens.views.commitDetails.files.layout": "tree",
    "claudeCode.preferredLocation": "panel",
    "claudeCode.selectedModel": "opus",
    "claudeCode.environmentVariables": [

    ],
    "terminal.integrated.enableVisualBell": true,
    "gitlens.graph.minimap.additionalTypes": [
        "localBranches",
        "stashes",
        "pullRequests",
        "remoteBranches"
    ],
    "sonarlint.focusOnNewCode": false,
    "github.copilot.chat.copilotMemory.enabled": true,
    "simpleBrowser.useIntegratedBrowser": true,
    "workbench.settings.alwaysShowAdvancedSettings": true,
    "chat.customAgentInSubagent.enabled": true,
    "github.copilot.chat.searchSubagent.enabled": true,
    "github.copilot.chat.agentCustomizationSkill.enabled": true,
    "terminal.integrated.enableKittyKeyboardProtocol": true,
    "json.schemaDownload.trustedDomains": {
        "https://schemastore.azurewebsites.net/": true,
        "https://raw.githubusercontent.com/": true,
        "https://www.schemastore.org/": true,
        "https://json.schemastore.org/": true,
        "https://json-schema.org/": true,
        "https://ui.shadcn.com": true
    },
    "chat.tools.terminal.terminalProfile.osx": {
        "path": "bash"
    },
    "gitlens.rebaseEditor.ordering": "asc",
    "inlineChat.affordance": "editor",
    "accessibility.chat.showCheckmarks": true,
    "terminal.integrated.enableImages": true,
    "terminal.external.osxExec": "Ghostty.app",
    "workbench.browser.enableChatTools": true,
    "sonarlint.analysisExcludesStandalone": "",
    "workbench.browser.showInTitleBar": true,
    "terminal.integrated.profiles.osx": {
        "bash": {
            "path": "bash",
            "args": [
                "-l"
            ],
            "icon": "terminal-bash"
        },
        "zsh": {
            "path": "zsh",
            "args": [
                "-l"
            ]
        },
        "fish": {
            "path": "fish",
            "args": [
                "-l"
            ]
        },
        "tmux": {
            "path": "tmux",
            "icon": "terminal-tmux"
        },
        "pwsh": {
            "path": "pwsh",
            "icon": "terminal-powershell"
        }
    },
    "github.copilot.chat.agentDebugLog.enabled": true,
    "github.copilot.chat.agentDebugLog.fileLogging.enabled": true,
    "chat.tools.terminal.backgroundNotifications": true,
    "chat.tools.confirmationCarousel.enabled": true,
    "jsts-chat-features.skills.enabled": true,
    "inlineChat.fixDiagnostics": false,
    "chat.experimental.incrementalRendering.enabled": true,
    "github.copilot.chat.skillTool.enabled": true,
    "github.copilot.chat.responsesApi.toolSearchTool.enabled": true,
    "terminal.integrated.initialHint": false,
    "fallow.issueTypes": {
        "unused-files": true,
        "unused-exports": true,
        "unused-types": true,
        "private-type-leaks": true,
        "unused-dependencies": true,
        "unused-dev-dependencies": true,
        "unused-optional-dependencies": true,
        "unused-enum-members": true,
        "unused-class-members": true,
        "unresolved-imports": true,
        "unlisted-dependencies": true,
        "duplicate-exports": true,
        "type-only-dependencies": true,
        "test-only-dependencies": true,
        "circular-dependencies": true,
        "re-export-cycles": true,
        "boundary-violation": true,
        "stale-suppressions": true,
        "unused-catalog-entries": true,
        "unresolved-catalog-references": true,
        "unused-dependency-overrides": true,
        "misconfigured-dependency-overrides": true
    },
    "chat.viewSessions.orientation": "stacked",
}

