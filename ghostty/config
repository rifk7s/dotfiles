# Shift+Enter for Claude Code / Factory Droid (must be at top)
# Try sending both ESC and newline for compatibility
keybind = shift+enter=text:\x1b\n

# Theme & Appearance
theme = Catppuccin Mocha
# theme = Vesper
# theme = dark:Catppuccin Mocha,light:Catppuccin Latte

# window-theme = system
window-colorspace = "display-p3"
macos-icon = blueprint
macos-titlebar-style = "tabs"


# Font Settings
font-family = "JetBrainsMono Nerd Font"
font-size = 16
font-thicken = true
bold-is-bright = false
# window-title-font-family = Hack Nerd Font Propo


# Cursor Settings
cursor-style = "block"
cursor-style-blink = true
cursor-invert-fg-bg = true


# Window Settings
window-decoration = true
window-save-state = always
window-new-tab-position = "end"
window-padding-x = 4,2
window-padding-y = 6,0
window-padding-balance = true
# adjust-cell-height = 25%

macos-window-shadow = false


# Backgrund & Transparency
background-opacity = 0.75
background-blur = true
background-blur-radius = 40
# unfocused-split-opacity = 0.4
# unfocused-split-fill = "#444444"


# Shell Integration
shell-integration = detect
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo
command = zsh --login

# Working Directory
working-directory = home
# working-directory = inherit
window-inherit-working-directory = true


# Mouse Settings
focus-follows-mouse = true
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2


# Clipboard Settings
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
copy-on-select = clipboard


# Links
link-url = true


# macOS Specific
macos-option-as-alt = true


# Quick Terminal
quick-terminal-animation-duration = 0.08
confirm-close-surface = false


# Auto Update
auto-update = download
auto-update-channel = stable


