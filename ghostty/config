# --- Ghostty Configuration ---

# scrollback-limit = 100000000
scrollback-limit = 100000

# Theme & Appearance
# theme = "/Users/rifky/.config/ghostty/themes/ghostty-themez"
theme = Catppuccin Macchiato
# theme = Vesper

# theme = Catppuccin Mocha


# config-file = themes/tokyonight
# config-file = themes/linkarzu
term = xterm-256color
window-colorspace = "display-p3"
macos-icon = official
# window-theme = system

# Window
window-decoration = true
macos-titlebar-style = "transparent"
macos-titlebar-proxy-icon = "visible"
macos-window-shadow = false

window-save-state = always
window-new-tab-position = "end"
window-padding-x = 4,2
window-padding-y = 6,0   
window-padding-balance = true
resize-overlay = never

# Background
# unfocused-split-fill = "#444444"
background-opacity = 0.78
background-image-fit = "cover"
split-divider-color = #524f67
unfocused-split-opacity = 0.7
# background-blur = true
# background-blur = macos-glass-clear
# background-blur-radius = 10
# blur disabled: causes grey overlay in window screenshots (Cmd+Shift+5 -> Capture Selected Window)

# Font
font-family = "JetBrainsMonoNL Nerd Font"
font-size = 16
font-feature = -liga,-calt,-dlig
font-thicken = true
# bold-is-bright = false (deprecated)
adjust-cell-height = 30%
# window-title-font-family = Hack Nerd Font Propo

# Cursor
cursor-style = "block"
cursor-style-blink = false
cursor-invert-fg-bg = true
cursor-color = cell-foreground
cursor-text = cell-background

# Mouse & Interaction
# focus-follows-mouse = true (disabled: annoying accidental focus changes)
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2
confirm-close-surface = false
link-url = true

# Clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
copy-on-select = clipboard

# Shell Integration
shell-integration = detect
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo
# shell-integration-features = no-cursor
command = zsh --login

# Working Directory
working-directory = home
# working-directory = inherit
window-inherit-working-directory = false
tab-inherit-working-directory = true
split-inherit-working-directory = true

# macOS Specific
macos-option-as-alt = true

# Quick Terminal
quick-terminal-animation-duration = 0.08

# Auto Update
auto-update = check
auto-update-channel = stable

