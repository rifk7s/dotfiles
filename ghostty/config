# --- Keybindings ---

# Custom Text Inputs
# Shift+Enter for Claude Code / Factory Droid
# Try sending both ESC and newline for compatibility
keybind = shift+enter=text:\x1b\n

# Quick Terminal
keybind = cmd+s=toggle_quick_terminal

# Inspector & Config
keybind = super+i=inspector:toggle
keybind = super+r=reload_config

# Tab Navigation
# keybind = super+left=previous_tab
# keybind = super+right=next_tab

# Split Management
keybind = super+ctrl+0=equalize_splits

# Split Navigation
# Splits and tabs are different, so this is external navigation
# keybind = super+b>h=goto_split:left
# keybind = super+b>j=goto_split:bottom
# keybind = super+b>k=goto_split:top
# keybind = super+b>l=goto_split:right
keybind = super+b>left=goto_split:left
keybind = super+b>down=goto_split:bottom
keybind = super+b>up=goto_split:top
keybind = super+b>right=goto_split:right

# Similar to Tmux Panes (no sessions)
# this only works if you have `macos-titlebar-style = tabs or native or transparent` else it behaves like new window
keybind = ctrl+space>c=new_tab
keybind = ctrl+space>n=new_window
keybind = ctrl+space>x=close_surface


notify-on-command-finish = always
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s
